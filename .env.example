APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost:8000

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=feactiva_iglesia_saas
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_SECURE=false
AUTH_TOKEN_TTL_SECONDS=86400
CORS_ALLOWED_ORIGINS=http://localhost:9090,http://127.0.0.1:9090,http://localhost:8000,http://127.0.0.1:8000
DEFAULT_TENANT_ID=1
WHATSAPP_INTEGRATION_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_ORIGIN=https://feactiva.cl/whatsapp/webhook.php
WHATSAPP_INTERNAL_IDENTIFY_URL=https://iglesia.feactiva.cl/internal/whatsapp/identify.php
WHATSAPP_INTERNAL_MESSAGE_URL=https://iglesia.feactiva.cl/internal/whatsapp/message.php
AGENT_INTERNAL_ONTOLOGY_URL=https://iglesia.feactiva.cl/internal/agent/ontology.php
AGENT_INTERNAL_EXECUTE_URL=https://iglesia.feactiva.cl/internal/agent/execute.php

# Agenda multicanal / proveedores externos
AGENDA_EMAIL_ENABLED=false
AGENDA_EMAIL_PROVIDER=
AGENDA_EMAIL_FROM=
AGENDA_WHATSAPP_SEND_ENABLED=false
AGENDA_GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://iglesia.feactiva.cl/api/v1/integrations/google/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=
SPEECH_TO_TEXT_ENABLED=false
SPEECH_TO_TEXT_PROVIDER=
TEXT_TO_SPEECH_ENABLED=false
TEXT_TO_SPEECH_PROVIDER=

STORAGE_PATH=storage
LOG_PATH=logs

